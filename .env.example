# ══════════════════════════════════════════════
# EcoAlert — Production Environment Variables
# ══════════════════════════════════════════════
# INSTRUCCIONES: Copia este archivo como .env y completa los valores reales
# NUNCA subas .env a git — está en .gitignore

NODE_ENV=development
PORT=3000

# ── MONGODB ATLAS ──────────────────────────────
# 1. Ve a mongodb.com/cloud/atlas
# 2. Crea cluster gratuito (M0)
# 3. Database Access → Add User
# 4. Network Access → Allow 0.0.0.0/0
# 5. Connect → Drivers → copia la URI
MONGODB_URI=mongodb+srv://USUARIO:PASSWORD@cluster0.xxxxx.mongodb.net/ecoalert?retryWrites=true&w=majority

# ── JWT ────────────────────────────────────────
# Genera con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CAMBIA_ESTO_por_un_string_aleatorio_de_64_bytes
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=CAMBIA_ESTO_otro_string_aleatorio_diferente
JWT_REFRESH_EXPIRES_IN=7d

# ── CLOUDINARY ────────────────────────────────
# 1. Ve a cloudinary.com → Sign Up gratuito
# 2. Dashboard → API Keys
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret
CLOUDINARY_FOLDER=ecoalert

# ── FIREBASE ADMIN (Push Notifications) ───────
# 1. console.firebase.google.com → Nuevo proyecto
# 2. Configuración → Cuentas de servicio → Generar clave privada
# 3. Pega el JSON en una línea (escapa las comillas)
FIREBASE_PROJECT_ID=tu-proyecto-firebase
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@tu-proyecto.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nTU_CLAVE_PRIVADA\n-----END PRIVATE KEY-----\n"

# ── OPENAI (IA detección de basura) ───────────
# console.platform.openai.com → API Keys → Create new secret key
# Habilita acceso a gpt-4o en tu cuenta
OPENAI_API_KEY=sk-proj-TU_CLAVE_OPENAI_AQUI

# ── GOOGLE MAPS ────────────────────────────────
# console.cloud.google.com → Maps JavaScript API
GOOGLE_MAPS_API_KEY=AIzaSy_TU_CLAVE_DE_GOOGLE_MAPS

# ── CORS ───────────────────────────────────────
# En producción, pon solo tu dominio: https://tuapp.com
FRONTEND_URL=http://localhost:5500

# ── RATE LIMITING ──────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ── LOGS ───────────────────────────────────────
LOG_LEVEL=debug
LOG_DIR=./logs
